# ==============================================================================
# WGCNA FOR TRANSCRIPTOME DATA ONLY
# Adapted treatments:
# C_12h, C_48h, C_1w, T_12h, T_48h, T_1w
# ==============================================================================

rm(list = ls())
options(stringsAsFactors = FALSE)

# =========================
# 1) PACKAGES
# =========================
required_pkgs <- c(
  "WGCNA",
  "dynamicTreeCut",
  "fastcluster",
  "data.table",
  "readxl",
  "ggplot2",
  "dplyr",
  "tidyr",
  "stringr"
)

for (p in required_pkgs) {
  if (!requireNamespace(p, quietly = TRUE)) {
    install.packages(p, repos = "https://cloud.r-project.org")
  }
}

library(WGCNA)
library(dynamicTreeCut)
library(fastcluster)
library(data.table)
library(readxl)
library(ggplot2)
library(dplyr)
library(tidyr)
library(stringr)

allowWGCNAThreads()

# =========================
# 2) INPUT FILE
# =========================
expr_file <- "Ale_Matriz_Normalizada_log2CPM.xlsx"

resdir  <- "wgcna_results_C_T_time"
figdir  <- file.path(resdir, "figures")
cytodir <- file.path(resdir, "cytoscape")
cyto_top50_dir <- file.path(resdir, "cytoscape_top50_ready")

dir.create(resdir, showWarnings = FALSE, recursive = TRUE)
dir.create(figdir, showWarnings = FALSE, recursive = TRUE)
dir.create(cytodir, showWarnings = FALSE, recursive = TRUE)
dir.create(cyto_top50_dir, showWarnings = FALSE, recursive = TRUE)

# =========================
# 3) READ TRANSCRIPTOME
# =========================
expr_raw <- read_excel(
  expr_file,
  sheet = "Matriz_Normalizada_log2CPM"
)

expr_raw <- as.data.frame(expr_raw)

colnames(expr_raw)[1] <- gsub("^\\ufeff", "", colnames(expr_raw)[1])

# =========================
# 4) DEFINE COLUMNS
# =========================
meta_cols <- c("geneName", "GeneID")

sample_cols <- grep(
  "^(C|T)_(12h|48h|1w)_rep[0-9]+$",
  colnames(expr_raw),
  value = TRUE
)

sample_cols <- sample_cols[sample_cols %in% colnames(expr_raw)]

if (length(sample_cols) < 2) {
  stop("Poucas colunas de amostras encontradas. Verifique os nomes: C_12h, C_48h, C_1w, T_12h, T_48h, T_1w")
}

# =========================
# 5) GENE LABEL
# =========================
expr_raw$GeneLabel <- make.unique(
  paste(
    expr_raw$GeneID,
    expr_raw$geneName,
    sep = "_"
  )
)

# =========================
# 6) EXPRESSION MATRIX
# =========================
expr_mat <- expr_raw[, sample_cols, drop = FALSE]
rownames(expr_mat) <- expr_raw$GeneLabel

expr_mat[] <- lapply(
  expr_mat,
  function(x) as.numeric(as.character(x))
)

na_gene <- rowSums(is.na(expr_mat)) > 0

if (any(na_gene)) {
  message(sum(na_gene), " genes removed due to missing values.")
  expr_mat <- expr_mat[!na_gene, , drop = FALSE]
}

expr_raw2 <- expr_raw[
  match(rownames(expr_mat), expr_raw$GeneLabel),
  ,
  drop = FALSE
]

# =========================
# 7) SAMPLE INFORMATION
# =========================
sample_info <- data.frame(
  Sample = colnames(expr_mat),
  Treatment = colnames(expr_mat),
  stringsAsFactors = FALSE
)

sample_info$Treatment <- factor(
  sample_info$Treatment,
  levels = c(
    "C_12h",
    "C_48h",
    "C_1w",
    "T_12h",
    "T_48h",
    "T_1w"
  )
)

write.csv(
  sample_info,
  file = file.path(resdir, "sample_info.csv"),
  row.names = FALSE
)

# =========================
# 8) PREPARE FOR WGCNA
# =========================
datExpr <- as.data.frame(t(expr_mat))

gsg <- goodSamplesGenes(datExpr, verbose = 3)

if (!gsg$allOK) {
  
  if (sum(!gsg$goodGenes) > 0) {
    message(
      "Removing genes: ",
      paste(colnames(datExpr)[!gsg$goodGenes], collapse = ", ")
    )
  }
  
  if (sum(!gsg$goodSamples) > 0) {
    message(
      "Removing samples: ",
      paste(rownames(datExpr)[!gsg$goodSamples], collapse = ", ")
    )
  }
  
  datExpr <- datExpr[
    gsg$goodSamples,
    gsg$goodGenes,
    drop = FALSE
  ]
  
  sample_info <- sample_info[
    match(rownames(datExpr), sample_info$Sample),
    ,
    drop = FALSE
  ]
}

# =========================
# 9) SAMPLE CLUSTERING
# =========================
