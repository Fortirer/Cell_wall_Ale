    top_n_genes = 80,
    edge_threshold = 0.10
  )
}

# =========================
# 23) CYTOSCAPE EXPORT TOP50 HUBS READY
# =========================
node_info_base <- hub_table %>%
  left_join(
    module_membership_wide,
    by = c("GeneLabel", "ModuleColor")
  ) %>%
  select(
    GeneLabel,
    ModuleColor,
    GeneID,
    geneName,
    kWithin,
    kOut,
    kTotal,
    MM,
    MM_abs,
    MM_pvalue
  )

modules <- unique(
  top50_hubs_each_module$ModuleColor
)

for (mod in modules) {
  
  cat("\nProcessing module:", mod, "\n")
  
  top_genes_df <- top50_hubs_each_module %>%
    filter(ModuleColor == mod) %>%
    arrange(HubRank)
  
  top_genes <- unique(
    top_genes_df$GeneLabel
  )
  
  if (length(top_genes) < 2) {
    cat(
      "Module",
      mod,
      "skipped: less than 2 genes.\n"
    )
    next
  }
  
  inModule <- moduleColors == mod
  mod_genes <- colnames(datExpr)[inModule]
  
  if (length(mod_genes) < 2) {
    cat(
      "Module",
      mod,
      "skipped: module has less than 2 genes in datExpr.\n"
    )
    next
  }
  
  mod_TOM <- TOM[inModule, inModule]
  
  dimnames(mod_TOM) <- list(
    mod_genes,
    mod_genes
  )
  
  keep_genes <- intersect(
    top_genes,
    mod_genes
  )
  
  if (length(keep_genes) < 2) {
    cat(
      "Module",
      mod,
      "skipped: insufficient intersection.\n"
    )
    next
  }
  
  mod_TOM_top <- mod_TOM[
    keep_genes,
    keep_genes,
    drop = FALSE
  ]
  
  node_annot <- node_info_base %>%
    filter(GeneLabel %in% keep_genes) %>%
    distinct(
      GeneLabel,
      .keep_all = TRUE
    )
  
  node_annot <- node_annot[
    match(
      keep_genes,
      node_annot$GeneLabel
    ),
    ,
    drop = FALSE
  ]
  
  edge_file <- file.path(
    cyto_top50_dir,
    paste0(
      "edges_top50_module_",
      mod,
      ".txt"
    )
  )
  
  node_file <- file.path(
    cyto_top50_dir,
    paste0(
      "nodes_top50_module_",
      mod,
      ".txt"
    )
  )
  
  exportNetworkToCytoscape(
    mod_TOM_top,
    weighted = TRUE,
    threshold = 0.10,
    edgeFile = edge_file,
    nodeFile = node_file,
    nodeNames = keep_genes,
    altNodeNames = keep_genes,
    nodeAttr = mod
  )
  
  write.csv(
    node_annot,
    file.path(
      cyto_top50_dir,
      paste0(
        "node_annotation_top50_module_",
        mod,
        ".csv"
      )
    ),
    row.names = FALSE
  )
  
  cat("Files created for module:", mod, "\n")
}

