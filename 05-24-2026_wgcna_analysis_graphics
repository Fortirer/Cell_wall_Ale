# =========================
# 21) EIGENGENE PLOTS BY TREATMENT
# =========================
plot_ME_by_treatment <- function(module_name, outname) {
  
  if (!(module_name %in% colnames(module_eigengenes))) {
    return(NULL)
  }
  
  df <- module_eigengenes %>%
    select(
      Sample,
      Treatment,
      all_of(module_name)
    ) %>%
    rename(
      Eigengene = all_of(module_name)
    )
  
  p <- ggplot(
    df,
    aes(
      x = Treatment,
      y = Eigengene
    )
  ) +
    geom_boxplot(
      outlier.shape = NA,
      linewidth = 0.5
    ) +
    geom_jitter(
      width = 0.12,
      size = 2,
      alpha = 0.8
    ) +
    theme_classic(base_size = 12) +
    labs(
      title = paste0(
        module_name,
        " eigengene by treatment"
      ),
      x = NULL,
      y = "Module eigengene"
    ) +
    theme(
      axis.text.x = element_text(
        angle = 45,
        hjust = 1
      )
    )
  
  ggsave(
    outname,
    p,
    width = 6,
    height = 4.5,
    dpi = 300
  )
}

