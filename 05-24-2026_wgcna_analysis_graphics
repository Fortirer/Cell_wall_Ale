# =========================
# 10) SOFT-THRESHOLD POWER
# =========================
powers <- c(1:10, seq(12, 30, by = 2))

sft <- pickSoftThreshold(
  datExpr,
  powerVector = powers,
  verbose = 5,
  networkType = "signed"
)

write.csv(
  sft$fitIndices,
  file = file.path(resdir, "soft_threshold_results.csv"),
  row.names = FALSE
)

