# =========================
# 15) MODULE MEMBERSHIP
# =========================
MM_list <- list()

for (me in names(MEs)) {
  
  mm <- cor(
    datExpr,
    MEs[[me]],
    use = "pairwise.complete.obs"
  )
  
  mp <- corPvalueStudent(
    mm,
    nSamples = nrow(datExpr)
  )
  
  tmp <- data.frame(
    GeneLabel = colnames(datExpr),
    Module = me,
    MM = as.numeric(mm),
    MM_abs = abs(as.numeric(mm)),
    MM_pvalue = as.numeric(mp),
    stringsAsFactors = FALSE
  )
  
  MM_list[[me]] <- tmp
}

