      )
    )
  )
}

# =========================
# 22) CYTOSCAPE EXPORT FOR ALL MODULES
# =========================
export_module_to_cytoscape <- function(
    module_color,
    top_n_genes = 80,
    edge_threshold = 0.10
) {
  
  inModule <- moduleColors == module_color
  mod_genes <- colnames(datExpr)[inModule]
  
  if (length(mod_genes) < 2) {
    return(NULL)
  }
  
  mod_adj <- adjacency_mat[inModule, inModule]
  rownames(mod_adj) <- mod_genes
  colnames(mod_adj) <- mod_genes
  
  conn <- rowSums(
    mod_adj,
    na.rm = TRUE
  )
  
  top_genes <- names(
    sort(
      conn,
      decreasing = TRUE
    )
  )[1:min(top_n_genes, length(conn))]
  
  mod_TOM <- TOM[inModule, inModule]
  dimnames(mod_TOM) <- list(
    mod_genes,
    mod_genes
  )
  
  mod_TOM_top <- mod_TOM[
    top_genes,
    top_genes,
    drop = FALSE
  ]
  
  node_annot <- module_assignments %>%
    filter(GeneLabel %in% top_genes) %>%
    select(
      GeneLabel,
      GeneID,
      geneName,
      ModuleColor
    )
  
  node_annot <- node_annot %>%
    left_join(
      hub_table %>%
        select(
          GeneLabel,
          kWithin,
          kTotal
        ),
      by = "GeneLabel"
    )
  
  exportNetworkToCytoscape(
    mod_TOM_top,
    edgeFile = file.path(
      cytodir,
      paste0(
        "module_",
        module_color,
        "_edges.txt"
      )
    ),
    nodeFile = file.path(
      cytodir,
      paste0(
        "module_",
        module_color,
        "_nodes.txt"
      )
    ),
    weighted = TRUE,
    threshold = edge_threshold,
    nodeNames = top_genes,
    altNodeNames = top_genes,
    nodeAttr = node_annot$ModuleColor
  )
  
  write.csv(
    node_annot,
    file.path(
      cytodir,
      paste0(
        "module_",
        module_color,
        "_node_annotation.csv"
      )
    ),
    row.names = FALSE
  )
}

for (mod in unique(moduleColors)) {
  if (mod == "grey") next
  
  export_module_to_cytoscape(
