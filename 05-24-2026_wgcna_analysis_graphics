} else {
  softPower <- 12
}

cat("Selected soft-threshold power:", softPower, "\n")

pdf(
  file.path(figdir, "soft_threshold_plots.pdf"),
  width = 12,
  height = 5
)

par(mfrow = c(1, 2))

plot(
  sft$fitIndices[, 1],
  -sign(sft$fitIndices[, 3]) * sft$fitIndices[, 2],
  xlab = "Soft Threshold (power)",
